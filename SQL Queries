-- Find the top 3 most purchased courses based on total quantity sold.

select
    course_name,
    category,
    total_quantity_sold

from
(
    select
        c.course_name,
        c.category,
        SUM(p.quantity) as total_quantity_sold
        from courses c

		inner join purchases p
        on c.course_id = p.course_id
       group by  c.course_name, c.category

) as course_sales
order by total_quantity_sold desc
limit 3;

-- 3.each course category total revenue and number of unique learners who purchased from that category --
with category_revenue as
(
select 
c.category ,
sum(p.quantity*c.unit_price) as total_revenue,
count(distinct p.learner_id) as unique_learners
from courses c
inner join purchases p 
on c.course_id=p.course_id 
group by c.category
) 
select category,
format(total_revenue,2) as final_total_revenue,
unique_learners
from category_revenue
order by total_revenue desc;


