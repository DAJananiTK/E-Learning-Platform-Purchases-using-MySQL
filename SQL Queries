-- 4. show  the learner purchased course from more than one category --


select learner_name,
 country,
 total_categories
 from
 (
 select 
 l.full_name as learner_name,
 country,
 count(distinct c.category) as total_categories
 from learners l
 join purchases p
 on l.learner_id=p.learner_id 
 join
 courses c 
 on p.course_id=c.course_id
 group by l.full_name,l.country
 )
 as multi_purchase
 having total_categories>1;
 
